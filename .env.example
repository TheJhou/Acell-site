# Connection string do PostgreSQL (Neon, Supabase, Railway ou local)
# Exemplo Neon: postgresql://user:pass@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# Exemplo local: postgresql://postgres:senha@localhost:5432/acell
DATABASE_URL=

# Chave de acesso ao painel /admin.html
ADMIN_KEY=

# Porta do servidor (opcional, padrão 5000)
PORT=
